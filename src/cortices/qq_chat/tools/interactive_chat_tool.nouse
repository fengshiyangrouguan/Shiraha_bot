import json
from typing import Dict, Any, List, Optional, TYPE_CHECKING

from sqlmodel import select

from src.cortices.tools_base import BaseTool
from src.agent.world_model import WorldModel
from src.cortices.qq_chat.chat.qq_chat_data import QQChatData
from src.common.database.database_manager import DatabaseManager
from src.common.database.database_model import EventDB
from src.llm_api.factory import LLMFactory
from src.cortices.qq_chat.chat.deep_chat.deep_chat_planner import DeepChatPlanner

if TYPE_CHECKING:
    from src.cortices.manager import CortexManager

class InteractiveChatTool(BaseTool):
    """
    该工具用于执行深度交互式聊天任务。
    它会进入一个指定的目标会话，并围绕一个特定目标，通过内部的DeepChatPlanner
    进行多轮的、有状态的对话，直到目标完成或达到退出条件。
    这是一个内部执行工具，不应由主规划器直接调用。
    """

    def __init__(self, world_model: WorldModel, cortex_manager: "CortexManager", database_manager: "DatabaseManager"):
        super().__init__(cortex_manager)
        self._world_model = world_model
        self.database_manager = database_manager
        self.llm_client = LLMFactory.create_llm_client()

    @property
    def scope(self) -> str:
        return "qq_app_internal"

    @property
    def metadata(self) -> Dict[str, Any]:
        return {
            "name": "interactive_chat",
            "description": "进入一个指定的聊天会话，并根据设定的目标进行多轮、有状态的交互。",
            "parameters": {
                "type": "object",
                "properties": {
                    "target_stream_id": {
                        "type": "string",
                        "description": "要进入的目标会话ID"
                    },
                    "chat_goal": {
                        "type": "string",
                        "description": "本次深度聊天的具体目标"
                    }
                },
                "required": ["target_stream_id", "chat_goal"]
            }
        }

    async def execute(self, target_stream_id: str, chat_goal: str) -> str:
        """执行交互式聊天循环"""
        qq_chat_data: QQChatData = await self._world_model.get_cortex_data("qq_chat_data")
        chat_stream = qq_chat_data.streams.get(target_stream_id) if qq_chat_data else None
        if not chat_stream:
            return f"无法找到ID为 {target_stream_id} 的聊天会话，或QQ未连接。"

        # 实例化内部专用的Planner
        planner = DeepChatPlanner(llm_client=self.llm_client)
        
        # 获取该循环可用的内部工具
        # 假设cortex_manager有方法可以按scope获取工具
        internal_tools_metadata = self.cortex_manager.get_tool_metadata_by_scope("qq_chat_internal")
        
        loop_history = []
        summary = f"在与 {chat_stream.conversation_info.conversation_name} 的聊天中未能达成目标。"

        # 设置最大循环次数以防止死循环
        for i in range(5):
            # 1. 获取最新消息作为当前世界状态
            query = select(EventDB).where(EventDB.conversation_id == chat_stream.conversation_info.conversation_id).order_by(EventDB.time.desc()).limit(20)
            messages_desc: List[EventDB] = await self.database_manager.get_all(query)
            recent_history = "
".join([f"{msg.user_nickname}: {msg.event_content}" for msg in reversed(messages_desc)])

            # 2. 内部Planner决策
            # 假设 plan 方法需要这些参数
            action = await planner.plan(
                chat_goal=chat_goal, 
                history=recent_history, 
                loop_history=loop_history, 
                available_tools=internal_tools_metadata
            )
            
            # 3. 执行或退出
            tool_to_call = action.get("tool_name")
            if not tool_to_call or tool_to_call == "exit_chat_mode":
                summary = f"在与 {chat_stream.conversation_info.conversation_name} 的聊天中达成了目标: {action.get('parameters', {}).get('reason', '无特定原因')}"
                chat_stream.mark_as_read() # 退出时标记为已读
                break
            
            tool_result = await self.cortex_manager.call_tool_by_name(
                tool_name=tool_to_call, 
                parameters=action.get("parameters", {}),
                scope="qq_chat_internal" # 明确指定调用内部工具
            )
            loop_history.append({"action": action, "result": tool_result})
            
            # 如果最后一步是发送消息，可以认为我们的目标可能已完成，提前退出
            if tool_to_call == "send_quick_reply":
                 summary = f"在与 {chat_stream.conversation_info.conversation_name} 的聊天中，发送了消息并结束了本次交互。"
                 chat_stream.mark_as_read()
                 break


        await self._world_model.save_cortex_data("qq_chat_data", qq_chat_data)
        return summary
